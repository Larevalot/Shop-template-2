---
interface Props {
  id: string;
  nombre: string;
  precio: number;
  imagen: string;
  descripcion: string;
  slug: string;
}

const { id, nombre, precio, imagen, descripcion, slug } = Astro.props;
---

<article class="product-card group relative bg-steel border border-dark-300 overflow-hidden transition-all duration-300 hover:border-neon/50 hover:shadow-[0_0_20px_rgba(0,255,136,0.15)]">
  <!-- Corner accents -->
  <div class="absolute top-0 left-0 w-3 h-3 border-t-2 border-l-2 border-neon/40"></div>
  <div class="absolute top-0 right-0 w-3 h-3 border-t-2 border-r-2 border-neon/40"></div>
  <div class="absolute bottom-0 left-0 w-3 h-3 border-b-2 border-l-2 border-neon/40"></div>
  <div class="absolute bottom-0 right-0 w-3 h-3 border-b-2 border-r-2 border-neon/40"></div>

  <a href={`/product/${slug}`} class="block">
    <div class="aspect-square overflow-hidden bg-carbon relative">
      <img
        src={imagen}
        alt={nombre}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-90 group-hover:opacity-100"
        loading="lazy"
      />
      <!-- Scanline on hover -->
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-neon/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
    </div>
    <div class="p-4 border-t border-dark-300">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-neon font-mono text-[10px] tracking-widest uppercase">ID:{id.slice(0, 6).toUpperCase()}</span>
      </div>
      <h3 class="text-base font-mono font-semibold text-light truncate uppercase tracking-wider">{nombre}</h3>
      <p class="mt-1 text-xs text-smoke line-clamp-2 font-mono">{descripcion}</p>
      <div class="mt-3 flex items-baseline gap-1">
        <span class="text-neon font-mono text-xs">$</span>
        <span class="text-2xl font-mono font-bold text-neon">{precio.toFixed(2)}</span>
      </div>
    </div>
  </a>
  <div class="p-4 pt-0">
    <button
      class="add-to-cart-btn w-full bg-dark-100 border border-neon/30 text-neon font-mono text-sm uppercase tracking-widest py-3 px-4 hover:bg-neon hover:text-carbon focus:outline-none focus:ring-2 focus:ring-neon focus:ring-offset-2 focus:ring-offset-steel transition-all duration-300"
      data-id={id}
      data-nombre={nombre}
      data-precio={precio}
      data-imagen={imagen}
    >
      + AGREGAR
    </button>
  </div>
  <div class="toast absolute top-4 right-4 bg-neon text-carbon px-4 py-2 font-mono text-xs uppercase tracking-wider shadow-[0_0_15px_rgba(0,255,136,0.5)] opacity-0 pointer-events-none transition-opacity duration-300">
    ✓ AGREGADO
  </div>
</article>

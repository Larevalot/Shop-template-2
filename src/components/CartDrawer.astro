---
---

<div
  id="cart-overlay"
  class="fixed inset-0 bg-carbon/80 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<aside
  id="cart-drawer"
  class="fixed top-0 right-0 h-full w-full max-w-md bg-steel border-l border-neon/20 shadow-[-10px_0_30px_rgba(0,255,136,0.1)] z-50 translate-x-full transition-transform duration-300 flex flex-col"
>
  <!-- Header -->
  <div class="flex items-center justify-between p-4 border-b border-neon/20 bg-carbon/50">
    <div class="flex items-center gap-3">
      <div class="w-2 h-2 bg-neon animate-pulse"></div>
      <h2 class="text-lg font-mono font-bold text-light tracking-wider uppercase">Carrito</h2>
    </div>
    <button
      id="close-drawer"
      class="p-2 text-smoke hover:text-neon focus:outline-none focus:ring-2 focus:ring-neon transition-colors duration-200"
      aria-label="Cerrar carrito"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Items -->
  <div id="cart-items" class="flex-1 overflow-y-auto p-4 space-y-3">
    <div id="empty-cart" class="flex flex-col items-center justify-center h-full text-smoke">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mb-4 text-dark-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
      </svg>
      <p class="text-sm font-mono uppercase tracking-wider">Carrito vacío</p>
      <p class="text-xs mt-1 font-mono text-dark-400">Agrega productos para continuar</p>
    </div>
    <div id="cart-items-list" class="space-y-3"></div>
  </div>

  <!-- Footer -->
  <div class="border-t border-neon/20 p-4 space-y-4 bg-carbon/30">
    <div>
      <label for="cart-notes" class="block text-xs font-mono text-smoke uppercase tracking-wider mb-2">
        Notas del pedido
      </label>
      <textarea
        id="cart-notes"
        rows="2"
        class="w-full px-3 py-2 bg-carbon border border-dark-300 text-light font-mono text-sm focus:outline-none focus:border-neon focus:ring-1 focus:ring-neon resize-none placeholder-dark-400"
        placeholder="Instrucciones especiales..."
      ></textarea>
    </div>

    <div class="flex items-center justify-between border-t border-dark-300 pt-4">
      <span class="text-smoke font-mono text-sm uppercase">Total</span>
      <div class="flex items-baseline gap-1">
        <span class="text-neon font-mono text-xs">$</span>
        <span id="cart-total" class="text-2xl font-mono font-bold text-neon">0.00</span>
      </div>
    </div>

    <button
      id="checkout-btn"
      class="w-full bg-whatsapp text-white font-mono text-sm uppercase tracking-widest py-3 px-4 hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-whatsapp focus:ring-offset-2 focus:ring-offset-steel transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed flex items-center justify-center gap-3"
      disabled
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      PEDIR POR WHATSAPP
    </button>
  </div>
</aside>
